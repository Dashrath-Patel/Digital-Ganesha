# Environment Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/ganesh_community
MONGODB_TEST_URI=mongodb://localhost:27017/ganesh_community_test

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_here
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Email Configuration (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@ganeshcommunity.com

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN=http://localhost:5174

# File Upload Limits
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
ALLOWED_VIDEO_TYPES=video/mp4,video/webm,video/ogg

# Redis Configuration (optional for caching)
REDIS_URL=redis://localhost:6379

# Admin Configuration
ADMIN_EMAIL=admin@ganeshcommunity.com
ADMIN_PASSWORD=admin123

# Socket.IO Configuration
SOCKET_CORS_ORIGIN=http://localhost:5174

# Notification Configuration
FCM_SERVER_KEY=your_fcm_server_key_here

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log
