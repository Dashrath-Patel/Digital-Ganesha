# Google OAuth Configuration
# Get this from Google Cloud Console: https://console.cloud.google.com/
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id-here

# Backend API URL
REACT_APP_API_URL=http://localhost:5000

# Environment
NODE_ENV=development

# Formspree Configuration for Contact Form
# Get your Form ID from https://formspree.io after creating a form
VITE_FORMSPREE_FORM_ID=YOUR_FORM_ID

# Optional: Your contact email for display purposes
VITE_CONTACT_EMAIL=support@digitalganesha.com

# Optional: Your phone number for display purposes
VITE_CONTACT_PHONE="+91-XXXX-XXXXXX"
